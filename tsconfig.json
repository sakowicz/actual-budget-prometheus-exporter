{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "lib": ["es2020"],
    "outDir": "./dist",
    "paths": {
      "@actual-app/core/*": ["./node_modules/@actual-app/core/src/*"]
    }
  }
}
