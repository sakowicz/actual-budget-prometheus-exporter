{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "lib": ["es2020"],
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@actual-app/core/server/api-models": ["./src/shims/actual-app-core-api-models"],
      "@actual-app/core/types/models": ["./src/shims/actual-app-core-types-models"],
      "@actual-app/core": ["./src/shims/empty"],
      "@actual-app/core/*": ["./src/shims/empty"]
    }
  }
}
